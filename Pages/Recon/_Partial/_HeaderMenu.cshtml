                else { <span class="ml-2 app-bar-name">Login</span>}}
            </a>
            <div class="user-block shadow-1" data-role="collapse" data-collapsed="true">
                <div class="bg-darkCyan fg-white p-2 text-middle">
                    <img src="/images/logo.png" class="avatar">
                    <div class="h4 mb-0">Logged: @userName</div>
                </div>
